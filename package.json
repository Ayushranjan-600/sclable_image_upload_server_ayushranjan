{
  "name": "image-upload-server",
  "version": "1.0.0",
  "description": "Production-ready image upload server with S3 storage and NGINX load balancing",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --forceExit",
    "lint": "eslint src/**/*.js",
    "start:3001": "set PORT=3001 && node src/server.js",
    "start:3002": "set PORT=3002 && node src/server.js"
  },
  "keywords": [
    "image",
    "upload",
    "s3",
    "express",
    "multer",
    "nginx",
    "load-balancer"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.400.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  }
}
